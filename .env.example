# ── LLM Backend ──────────────────────────────────────────────────────────────
# LLM_BACKEND controls which language model backend Aemu uses.
#   auto      — Try local Ollama first; fall back to Anthropic if unreachable (default)
#   ollama    — Always use local Ollama (fully offline, no API key needed)
#   anthropic — Always use Anthropic Claude API (requires ANTHROPIC_API_KEY)
LLM_BACKEND=auto

# Ollama local server settings (used when LLM_BACKEND=ollama or LLM_BACKEND=auto)
# Start Ollama: ollama serve
# Pull a model: ollama pull phi3.5
# See docs/ollama-local-setup.md for the full setup guide.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3.5

# ── Anthropic (cloud fallback) ────────────────────────────────────────────────
# Required only when LLM_BACKEND=anthropic or LLM_BACKEND=auto with no Ollama.
ANTHROPIC_API_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
AEMU_SESSION_SECRET=
AEMU_INTERNAL_API_SECRET=
AEMU_ADMIN_SETUP_KEY=
AEMU_PASSWORD_PEPPER=
INNER_BEING_BACKEND=native
CLAW_BRIDGE_URL=
CLAW_FALLBACK_TO_NATIVE=false
PIPER_MODEL=en_US-reza_ibrahim-medium
PIPER_PYTHON_PATH=
PIPER_DATA_DIR=
PIPER_HTTP_URL=
